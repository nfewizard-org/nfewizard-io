{
  "name": "@nfewizard/shared",
  "version": "1.0.0",
  "description": "Core utilities compartilhadas (XML, HTTP, Certificate, Schema)",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./xml": "./dist/esm/xml/index.js",
    "./http": "./dist/esm/http/index.js",
    "./certificate": "./dist/esm/certificate/index.js",
    "./utils": "./dist/esm/utils/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "xml",
    "soap",
    "certificate",
    "sefaz",
    "nfe-utils"
  ],
  "author": "maurelima",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nfewizard-org/nfewizard-io",
    "directory": "packages/shared"
  },
  "scripts": {
    "build": "rollup -c",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nfewizard/types": "workspace:*",
    "axios": "^1.7.7",
    "xml2js": "^0.6.2",
    "xml-js": "^1.6.11",
    "xml-crypto": "^6.0.0",
    "node-forge": "^1.3.1",
    "pako": "^2.1.0",
    "libxmljs2": "^0.37.0",
    "xsd-schema-validator": "^0.7.0",
    "xsd-assembler": "^0.0.3",
    "easy-soap-request": "^5.4.0",
    "soap": "^1.0.0",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "winston": "^3.17.0",
    "sha1": "^1.1.1",
    "ini": "^4.1.1",
    "pem": "^1.14.8"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
