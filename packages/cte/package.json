{
  "name": "@nfewizard/cte",
  "version": "1.0.1",
  "description": "Biblioteca Node.js para CTe - Conhecimento de Transporte Eletrônico",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "types": "./dist/src/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cte",
    "conhecimento transporte",
    "sefaz",
    "dfe"
  ],
  "author": "maurelima",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nfewizard-org/nfewizard-io",
    "directory": "packages/cte"
  },
  "scripts": {
    "build": "rollup -c",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@nfewizard/shared": "workspace:*",
    "@nfewizard/types": "workspace:*",
    "axios": "^1.15.0",
    "date-fns": "^2.30.0",
    "pako": "^2.1.0",
    "xml2js": "^0.6.2"
  },
  "optionalDependencies": {
    "@nfewizard/danfe": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/pako": "^2.0.4",
    "rollup": "^4.59.0",
    "typescript": "^5.4.5"
  }
}
