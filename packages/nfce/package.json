{
  "name": "@nfewizard/nfce",
  "version": "1.0.0",
  "description": "Biblioteca Node.js para NFCe - Nota Fiscal de Consumidor Eletrônica",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nfce",
    "nota fiscal consumidor",
    "sefaz",
    "dfe"
  ],
  "author": "maurelima",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nfewizard-org/nfewizard-io",
    "directory": "packages/nfce"
  },
  "scripts": {
    "build": "rollup -c",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@nfewizard/types": "workspace:*",
    "@nfewizard/shared": "workspace:*"
  },
  "optionalDependencies": {
    "@nfewizard/danfe": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
